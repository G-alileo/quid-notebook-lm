{
	"info": {
		"name": "Quid Auth API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/health"
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/register",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"TestPass123\",\n    \"full_name\": \"Test User\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/login",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"testuser\",\n    \"password\": \"TestPass123\"\n}"
						}
					}
				},
				{
					"name": "Login with Email",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/login",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"test@example.com\",\n    \"password\": \"TestPass123\"\n}"
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.access_token);",
									"    pm.collectionVariables.set('refresh_token', json.refresh_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/refresh",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
						}
					}
				},
				{
					"name": "Verify Token",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/auth/verify",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/logout",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/users/me",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						}
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PATCH",
						"url": "{{base_url}}/users/me",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						},
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"full_name\": \"Updated Name\"\n}"
						}
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/users/me/password",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						},
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"current_password\": \"TestPass123\",\n    \"new_password\": \"NewPass123\"\n}"
						}
					}
				},
				{
					"name": "Deactivate Account",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/users/me",
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}"
								}
							]
						}
					}
				}
			]
		}
	]
}
